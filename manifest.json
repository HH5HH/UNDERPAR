{
  "manifest_version": 3,
  "name": "UnderPAR",
  "short_name": "UP",
  "version": "1.26.57",
  "description": "UnderPAR (UP) PASS Acceleration Layer. Keep PASS workflows under par.",
  "minimum_chrome_version": "114.0.0.0",
  "key": "",
  "permissions": [
    "identity",
    "alarms",
    "storage",
    "downloads",
    "notifications",
    "sidePanel",
    "scripting",
    "tabs",
    "debugger",
    "webRequest",
    "webNavigation",
    "cookies",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://ims-na1.adobelogin.com/ims/*",
    "https://*.adobelogin.com/*",
    "https://*.adobe.com/*",
    "https://console.auth.adobe.com/*",
    "https://sp.auth.adobe.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://developer.adobe.com/adobe-pass/api/rest_api_v2/interactive/*"
      ],
      "js": [
        "restv2-docs-noise-guard.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "devtools_page": "devtools.html",
  "action": {
    "default_title": "UnderPAR",
    "default_icon": {
      "16": "icons/underpar-16.png",
      "24": "icons/underpar-24.png",
      "32": "icons/underpar-32.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/underpar-16.png",
    "32": "icons/underpar-32.png",
    "48": "icons/underpar-48.png",
    "128": "icons/underpar-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "esm-deeplink-bridge.html",
        "esm-deeplink-bridge.js",
        "blondie-time-deeplink-bridge.html",
        "blondie-time-deeplink-bridge.js",
        "esm-workspace.html",
        "esm-workspace.css",
        "esm-workspace.js",
        "blondie-time-workspace.html",
        "blondie-time-workspace.css",
        "blondie-time-workspace.js",
        "blondie-time-logic.js",
        "cm-workspace.html",
        "cm-workspace.css",
        "cm-workspace.js",
        "esm-health-workspace.html",
        "esm-health-workspace.css",
        "esm-health-workspace.js",
        "cm-health-workspace.html",
        "cm-health-workspace.css",
        "cm-health-workspace.js",
        "registered-application-health-workspace.html",
        "registered-application-health-workspace.css",
        "registered-application-health-workspace.js",
        "harpo.html",
        "harpo.css",
        "harpo.js",
        "harpo-idb.js",
        "harpo-platform.js",
        "harpo-restv2-learning.js",
        "harpo-traffic.js",
        "temp-pass-workspace.html",
        "temp-pass-workspace.css",
        "temp-pass-workspace.js",
        "degradation-workspace.html",
        "degradation-workspace.css",
        "degradation-workspace.js",
        "saved-query-bridge.html",
        "saved-query-bridge.js",
        "underpar-vault-store.js",
        "underpar-environment.js",
        "underpar_distro.zip",
        "underpar_distro.version.json"
      ],
      "matches": [
        "*://*/*",
        "file:///*"
      ]
    }
  ],
  "version_name": "1.26.57"
}
